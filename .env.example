# Server Configuration
PORT=4000
NODE_ENV=development

# SSH Configuration (Deployment Server)
SSH_HOST=your.server.ip.address
SSH_USER=root
SSH_PASSWORD=your_ssh_password
SSH_PORT=22

# Database Configuration (MongoDB)
MONGODB_URI=mongodb://localhost:27017/clawdeploy
# Or for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/clawdeploy

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=7d

# Domain Configuration
BASE_DOMAIN=your-domain.com

# Port Range for Deployments
MIN_PORT=3100
MAX_PORT=8900

# ClawdBot Configuration
CLAWDBOT_PATH=/root/.openclaw/workspace/server-dashboard/ai_deployer.py

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# GitHub OAuth Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://your-frontend-domain.com/auth/github/callback

# n8n + Automation Webhooks
N8N_ENABLED=true
N8N_CRITICAL_ALERT_WEBHOOK_URL=https://your-subdomain.app.n8n.cloud/webhook/critical-alert
N8N_DAILY_CALENDAR_WEBHOOK_URL=https://your-subdomain.app.n8n.cloud/webhook/daily-calendar
N8N_WEBHOOK_SHARED_SECRET=replace_with_random_shared_secret
INTERNAL_AUTOMATION_TOKEN=replace_with_random_internal_token

# Twilio WhatsApp (used by n8n workflow)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Calendar defaults for daily activity
GOOGLE_CALENDAR_ENABLED=true
GOOGLE_CALENDAR_DEFAULT_TIMEZONE=Asia/Kolkata
GOOGLE_CALENDAR_EVENT_HOUR=9
GOOGLE_CALENDAR_EVENT_MINUTE=0

# Razorpay Configuration (for payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret